# Optional OIDC configuration. Leave values empty to disable OIDC login.
PASSWORD_LOGIN_ENABLED=true
OIDC_PROVIDER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Optional historical weather enrichment for run details.
# open-meteo is free and does not require an API key.
WEATHER_PROVIDER=open-meteo
WEATHER_HTTP_TIMEOUT=8
